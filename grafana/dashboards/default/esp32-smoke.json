      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 5, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": {
        "unit": "ppb", "min": 0, "max": 1500,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 150 },
          { "color": "red", "value": 1300 }
        ] }
      } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "esphome_sensor_value{job=\"esp32-smoke\", name=\"ccs811_tvoc\"}" } ]
    },
    {
