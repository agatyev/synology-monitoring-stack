{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["esp32", "esphome", "air-quality"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "ESP32 Smoke — Air Quality",
  "uid": "esp32-smoke",
  "version": 1,
  "panels": [
    {
      "type": "row",
      "title": "CCS811 — запахи, дым, CO₂",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100
    },
    {
      "id": 1,
      "title": "Запахи и химия (VOC)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ppb",
          "color": { "mode": "thresholds" },
          "custom": { "fillOpacity": 12, "lineWidth": 2, "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 250 },
            { "color": "red", "value": 1000 }
          ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "esphome_sensor_value{job=\"esp32-smoke\", name=\"ccs811_tvoc\"}", "legendFormat": "TVOC" }
      ]
    },
    {
      "id": 2,
      "title": "Углекислый газ (CO₂)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "ppm",
          "color": { "mode": "thresholds" },
          "custom": { "fillOpacity": 12, "lineWidth": 2, "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 800 },
            { "color": "red", "value": 2000 }
          ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "esphome_sensor_value{job=\"esp32-smoke\", name=\"ccs811_eco2\"}", "legendFormat": "eCO2" }
      ]
    },
    {
      "type": "row",
      "title": "BME680 — климат и газ",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101
    },
    {
      "id": 3,
      "title": "Температура",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "thresholds" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null },
            { "color": "green", "value": 19 },
            { "color": "yellow", "value": 27 },
            { "color": "red", "value": 30 }
          ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "esphome_sensor_value{job=\"esp32-smoke\", name=\"bme680_temperature\"}", "legendFormat": "Temp" }
      ]
    },
    {
      "id": 4,
      "title": "Влажность",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "humidity",
          "color": { "mode": "thresholds" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "orange", "value": null },
            { "color": "green", "value": 40 },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 70 }
          ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "esphome_sensor_value{job=\"esp32-smoke\", name=\"bme680_humidity\"}", "legendFormat": "Humidity" }
      ]
    },
    {
      "id": 5,
      "title": "Давление",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "pressurehpa", "custom": { "fillOpacity": 10, "lineWidth": 2 } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "esphome_sensor_value{job=\"esp32-smoke\", name=\"bme680_pressure\"}", "legendFormat": "Pressure" }
      ]
    },
    {
      "id": 6,
      "title": "Газ — Падения = Загрязнение",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "ohm",
          "color": { "mode": "thresholds" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "thresholdsStyle": { "mode": "dashed" } },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 15000 },
            { "color": "green", "value": 30000 }
          ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "esphome_sensor_value{job=\"esp32-smoke\", name=\"bme680_gas_resistance\"}", "legendFormat": "Gas" }
      ]
    }
  ]
}
