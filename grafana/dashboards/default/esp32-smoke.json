      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "format": "table",
          "instant": true,
          "expr": "sum by (name) (esphome_sensor_value{job=\"esp32-smoke\", name=~\"ccs811_eco2|ccs811_tvoc|bme680_iaq|sps30_pm_2_5|sps30_pm_10_0\"})"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "format": "table",
          "instant": true,
          "expr": "sum by (name) ( max_over_time(esphome_sensor_value{job=\"esp32-smoke\", name=\"ccs811_eco2\"}[24h]) / 1000 or max_over_time(esphome_sensor_value{job=\"esp32-smoke\", name=\"ccs811_tvoc\"}[24h]) / 150 or max_over_time(esphome_sensor_value{job=\"esp32-smoke\", name=\"bme680_iaq\"}[24h]) / 100 or max_over_time(esphome_sensor_value{job=\"esp32-smoke\", name=\"sps30_pm_2_5\"}[24h]) / 12 or max_over_time(esphome_sensor_value{job=\"esp32-smoke\", name=\"sps30_pm_10_0\"}[24h]) / 54 ) * 100"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "name",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true
            },
            "renameByName": {
              "name": "Показатель",
              "Value #A": "Сейчас",
              "Value #C": "% нормы (24ч)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "% нормы (24ч)",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Показатель"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
