{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "System Info",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "System Status",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_system_status{instance=~\"$instance\"}", "legendFormat": "Status" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Normal", "color": "green" }, "2": { "text": "Failed", "color": "red" } } }
          ],
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 2 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Temperature",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_system_temperature{instance=~\"$instance\"}", "legendFormat": "°C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 45 }, { "color": "red", "value": 55 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Power Status",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_power_status{instance=~\"$instance\"}", "legendFormat": "Power" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Normal", "color": "green" }, "2": { "text": "Failed", "color": "red" } } }
          ],
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 2 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sysUpTime{instance=~\"$instance\"} / 100", "legendFormat": "Uptime" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Fan Status",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_system_fan_status{instance=~\"$instance\"}", "legendFormat": "System Fan" },
        { "expr": "synology_cpu_fan_status{instance=~\"$instance\"}", "legendFormat": "CPU Fan" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Normal", "color": "green" }, "2": { "text": "Failed", "color": "red" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "DSM Update",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_upgrade_available{instance=~\"$instance\"}", "legendFormat": "Upgrade" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "1": { "text": "Available", "color": "yellow" },
              "2": { "text": "Up to date", "color": "green" },
              "3": { "text": "Connecting", "color": "blue" },
              "4": { "text": "Disconnected", "color": "orange" },
              "5": { "text": "Other", "color": "purple" }
            }}
          ]
        },
        "overrides": []
      }
    },

    {
      "type": "row",
      "title": "CPU & Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "gauge",
      "title": "CPU Usage",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "100 - synology_cpu_idle{instance=~\"$instance\"}", "legendFormat": "CPU %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "CPU Over Time",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_cpu_user{instance=~\"$instance\"}", "legendFormat": "User" },
        { "expr": "synology_cpu_system{instance=~\"$instance\"}", "legendFormat": "System" },
        { "expr": "synology_cpu_idle{instance=~\"$instance\"}", "legendFormat": "Idle" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      }
    },
    {
      "type": "gauge",
      "title": "Memory Usage",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "(1 - synology_memory_available{instance=~\"$instance\"} / synology_memory_total{instance=~\"$instance\"}) * 100", "legendFormat": "RAM %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Memory Over Time",
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_memory_total{instance=~\"$instance\"}", "legendFormat": "Total" },
        { "expr": "synology_memory_total{instance=~\"$instance\"} - synology_memory_available{instance=~\"$instance\"}", "legendFormat": "Used" },
        { "expr": "synology_memory_cached{instance=~\"$instance\"}", "legendFormat": "Cached" },
        { "expr": "synology_memory_buffer{instance=~\"$instance\"}", "legendFormat": "Buffer" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "kbytes" },
        "overrides": []
      }
    },

    {
      "type": "row",
      "title": "Disk Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Disk Status",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_disk_status{instance=~\"$instance\"}", "legendFormat": "{{diskID}}", "format": "table", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "1": { "text": "Normal" }, "2": { "text": "Initialized" },
              "3": { "text": "Not Initialized" }, "4": { "text": "SysPartFailed" }, "5": { "text": "Crashed" }
            }}
          ]
        },
        "overrides": []
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true } } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Temperature",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_disk_temperature{instance=~\"$instance\"}", "legendFormat": "{{diskID}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 45 }, { "color": "red", "value": 55 } ] },
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      }
    },

    {
      "type": "row",
      "title": "RAID & Storage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "RAID Status",
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_raid_status{instance=~\"$instance\"}", "legendFormat": "{{raidName}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": {
              "1": { "text": "Normal", "color": "green" }, "2": { "text": "Repairing", "color": "yellow" },
              "11": { "text": "Degraded", "color": "red" }, "12": { "text": "Crashed", "color": "dark-red" }
            }}
          ]
        },
        "overrides": []
      }
    },
    {
      "type": "bargauge",
      "title": "Volume Usage",
      "gridPos": { "h": 5, "w": 16, "x": 8, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "(synology_raid_total_size{instance=~\"$instance\"} - synology_raid_free_size{instance=~\"$instance\"}) / synology_raid_total_size{instance=~\"$instance\"} * 100", "legendFormat": "{{raidName}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 } ] }
        },
        "overrides": []
      }
    },

    {
      "type": "row",
      "title": "Storage IO",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Disk Read Throughput",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(synology_storageio_nread{instance=~\"$instance\"}[5m])", "legendFormat": "{{device}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15 } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Disk Write Throughput",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(synology_storageio_nwritten{instance=~\"$instance\"}[5m])", "legendFormat": "{{device}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15 } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Disk IOPS",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(synology_storageio_reads{instance=~\"$instance\"}[5m])", "legendFormat": "read {{device}}" },
        { "expr": "rate(synology_storageio_writes{instance=~\"$instance\"}[5m])", "legendFormat": "write {{device}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "iops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Disk Load Average",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "synology_storageio_la{instance=~\"$instance\"}", "legendFormat": "{{device}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },

    {
      "type": "row",
      "title": "Network",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Network Inbound",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 45 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(ifHCInOctets{instance=~\"$instance\"}[5m]) * 8", "legendFormat": "{{ifDescr}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps", "custom": { "fillOpacity": 15 } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Network Outbound",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 45 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(ifHCOutOctets{instance=~\"$instance\"}[5m]) * 8", "legendFormat": "{{ifDescr}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps", "custom": { "fillOpacity": 15 } },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["synology", "nas", "snmp"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(synology_system_status, instance)",
        "current": {},
        "refresh": 1,
        "includeAll": true,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Synology NAS Overview",
  "uid": "synology-overview",
  "version": 1
}
