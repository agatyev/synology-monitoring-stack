{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row",
      "title": "Container Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Running Containers",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "count(container_last_seen{name!=\"\"})", "legendFormat": "Containers" }
      ],
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Container CPU Usage",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[5m]) * 100", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "fillOpacity": 15 } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Container Memory Usage",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "container_memory_usage_bytes{name!=\"\"}", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 15 } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Container Network RX",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(container_network_receive_bytes_total{name!=\"\"}[5m])", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15 } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Container Network TX",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(container_network_transmit_bytes_total{name!=\"\"}[5m])", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15 } },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Container Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "Container Logs (recent)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{job=\"docker-containers\", container=~\"$container\"}", "legendFormat": "" }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["docker", "containers", "cadvisor"],
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({job=\"docker-containers\"}, container)",
        "current": {},
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "title": "Docker Containers",
  "uid": "docker-containers",
  "version": 1
}
