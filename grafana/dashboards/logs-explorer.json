{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row",
      "title": "Synology Syslog",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Log Volume by Severity",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum by (severity) (count_over_time({job=\"synology-syslog\"} [$__interval]))", "legendFormat": "{{severity}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } } },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Log Volume by Application",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "sum by (app) (count_over_time({job=\"synology-syslog\"} [$__interval]))", "legendFormat": "{{app}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } } },
        "overrides": []
      }
    },
    {
      "type": "logs",
      "title": "All Synology Logs",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{job=\"synology-syslog\", severity=~\"$severity\"} |= \"$search\"", "legendFormat": "" }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Docker Container Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },
    {
      "type": "logs",
      "title": "Container Logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{job=\"docker-containers\", container=~\"$container\"} |= \"$search\"", "legendFormat": "" }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "type": "logs",
      "title": "Errors & Warnings (all sources)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 40 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{job=\"synology-syslog\", severity=~\"err|crit|alert|emerg|warning\"}", "legendFormat": "" },
        { "expr": "{job=\"docker-containers\"} |~ \"(?i)(error|critical|fatal)\"", "legendFormat": "" }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["logs", "loki", "synology", "syslog", "docker"],
  "templating": {
    "list": [
      {
        "name": "search",
        "type": "textbox",
        "current": { "value": "" },
        "label": "Search"
      },
      {
        "name": "severity",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({job=\"synology-syslog\"}, severity)",
        "current": {},
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({job=\"docker-containers\"}, container)",
        "current": {},
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Logs Explorer",
  "uid": "logs-explorer",
  "version": 1
}
